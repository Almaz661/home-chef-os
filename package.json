{
  "name": "home-chef-os",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"npm run dev:web\" \"npm run dev:api\"",
    "dev:web": "vite",
    "dev:api": "tsx watch server/index.ts",
    "build": "vite build",
    "start": "npm run build && NODE_ENV=production tsx server/index.ts",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.server.json",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:seed": "tsx server/db/seed-cli.ts",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.1.5",
    "@trpc/client": "^11.0.0",
    "@trpc/react-query": "^11.0.0",
    "@trpc/server": "^11.0.0",
    "@tanstack/react-query": "^5.59.0",
    "@vitejs/plugin-react": "^4.3.3",
    "cheerio": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "drizzle-orm": "^0.36.0",
    "express": "^4.21.0",
    "iconv-lite": "^0.6.3",
    "lucide-react": "^0.460.0",
    "nanoid": "^5.0.7",
    "postgres": "^3.4.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "superjson": "^2.2.1",
    "tailwindcss": "^4.1.5",
    "tsx": "^4.19.1",
    "vite": "^5.4.10",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "concurrently": "^9.0.1",
    "drizzle-kit": "^0.27.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
