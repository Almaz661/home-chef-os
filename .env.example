# =====================================================================
# Server
# =====================================================================
PORT=3000
NODE_ENV=development

# =====================================================================
# Database — PostgreSQL (Neon)
# =====================================================================
# Connection string PostgreSQL. Поддерживаются:
#   - Neon: console.neon.tech → Project → Connection Details → Pooled
#   - любой другой PostgreSQL (Supabase, Railway, локальный docker и т.д.)
#
# Формат:
#   postgres://user:password@host:5432/dbname?sslmode=require
#
# ВАЖНО: на Neon используйте именно "Pooled connection" string —
# она использует pgbouncer и держит соединения долго, что нужно для
# serverless-окружений типа Render Free.
DATABASE_URL=postgres://USER:PASSWORD@HOST/DBNAME?sslmode=require

# =====================================================================
# Optional integrations (Этап 2)
# Все ключи опциональны. Без них приложение работает, но:
#  - без OCR_*: сканер чеков создаёт пустую запись, позиции вводятся вручную
#  - без DEEPL/GOOGLE: голландские названия остаются на голландском
#  - курс валют работает БЕЗ ключа (Frankfurter / open.er-api.com)
# =====================================================================

# -- Сканирование чеков (выберите один из двух) --
# OCR.space — бесплатно 25 000 запросов/мес, поддерживает голландский
# https://ocr.space/ocrapi (получить ключ → раздел "Free API key")
# OCR_SPACE_API_KEY=

# Google Cloud Vision — точнее, бесплатно 1000 запросов/мес
# https://console.cloud.google.com/apis/library/vision.googleapis.com
# GOOGLE_VISION_API_KEY=

# -- Перевод названий (выберите один из двух) --
# DeepL — бесплатно 500 000 символов/мес, лучшее качество для NL/RU
# https://www.deepl.com/pro-api → "DeepL API Free"
# DEEPL_API_KEY=
# По умолчанию используется free-сервер. Если у вас платный план — замените:
# DEEPL_API_URL=https://api.deepl.com

# Google Cloud Translation — fallback
# https://console.cloud.google.com/apis/library/translate.googleapis.com
# GOOGLE_TRANSLATE_API_KEY=
